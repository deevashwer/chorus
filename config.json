{
  "compute_vm": {
    "name": "chorus-compute",
    "machine_type": "c2d-standard-112",
    "boot_disk_size": "200GB",
    "image_family": "ubuntu-2204-lts",
    "image_project": "ubuntu-os-cloud"
  },
  "bench_cases": [
    {
      "case": 1,
      "corrupt_fraction": 10,
      "fail_fraction": 50,
      "threshold": 30,
      "committee_size": 100
    }
  ],
  "nivss_cases": [
    { "case": 1, "fraction": 1,  "threshold": 10,  "committee_size": 50 }
  ],
  "nivss_receive_parallel": 8,
  "num_clients": ["1M"],
  "network": {
    "server_bind_ip": "0.0.0.0",
    "server_port": 32000
  },
  "network_limit": {
    "bandwidth_mbps": 75,
    "rtt_ms": 280
  },
  "experiments": {
    "figure5": {
      "description": "Figure 5: saVSS vs cgVSS runtime and communication",
      "expected_minutes": 120,
      "server_vm": "compute",
      "client_vm": "control",
      "steps": [
        { "vm": "compute", "bench": "sa_nivss", "mode": "server", "log": "sa_nivss_server.log" },
        { "vm": "control", "bench": "sa_nivss", "mode": "client", "log": "sa_nivss_client_parallel.log" },
        { "vm": "control", "bench": "pv_nivss", "mode": null,     "log": "pv_nivss_client_parallel.log" }
      ],
      "plots": ["nivss-time.png", "nivss-comm.png", "nivss-legend.png"]
    },
    "table10": {
      "description": "Table 10: Parameter selection (n, threshold) vs. corruption/offline fractions",
      "expected_minutes": 1,
      "steps": [],
      "plots": ["table10.tex"],
      "corruption_fractions": [0.01, 0.05, 0.10, 0.15, 0.20],
      "availability_fractions": [0.25, 0.50, 0.75],
      "comp_sec": 128,
      "stat_sec": 80,
      "n_clients": 1000000
    },
    "secret_recovery": {
      "description": "Tables 6, 7, 9, Figure 8, Appendix A.4.1: Secret recovery end-to-end",
      "expected_minutes": 240,
      "steps": [
        { "vm": "compute", "bench": "secret_recovery", "mode": "server", "log": "secret_recovery_server.log" },
        { "vm": "control", "bench": "secret_recovery", "mode": "client", "log": "secret_recovery_client.log" }
      ],
      "plots": [
        "table6.tex", "table7.tex", "table9.tex", "appendixA41.tex",
        "client_breakdown_Time.png", "client_breakdown_Comm.png",
        "client-breakdown-legend.png"
      ]
    }
  }
}
